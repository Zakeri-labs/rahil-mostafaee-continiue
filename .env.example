# Public origin used for canonical absolute sitemap and robots URLs.
NEXT_PUBLIC_SITE_URL=https://example.com

# Confidential case intake email configuration.
# Set CASE_INTAKE_DEV_MODE=true locally to validate and log a safe summary
# without contacting Resend. Keep these values server-side only.
RESEND_API_KEY="re_your_key_here"
CASE_INTAKE_FROM_EMAIL="Case Review <verified-sender@example.com>"
CASE_INTAKE_RECIPIENTS="first-recipient@example.com,second-recipient@example.com"
CASE_INTAKE_DEV_MODE="true"
CASE_INTAKE_REPLY_TO_EMAIL=""
